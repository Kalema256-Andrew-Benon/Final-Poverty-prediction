                "46-55",
                "56-65",
                "66+"
            ],
            "mapping": {
                "18-25": 0,
                "26-35": 1,
                "36-45": 2,
                "46-55": 3,
                "56-65": 4,
                "66+": 5
            }
        },
        "monthly_income_binned": {
            "method": "binning + label_encode",
            "bins": [
                0,
                50000,
                100000,
                200000,
                500000,
                1000000,
                "inf"
            ],
            "labels": [
                "<50k",
                "50k-100k",
                "100k-200k",
                "200k-500k",
                "500k-1M",
                ">1M"
            ],
            "mapping": {
                "<50k": 0,
                "50k-100k": 1,
                "100k-200k": 2,
                "200k-500k": 3,
                "500k-1M": 4,
                ">1M": 5
            }
        },
        "household_size_binned": {
            "method": "binning + label_encode",
            "bins": [
                0,
                2,
                4,
                6,
                8,
                20
            ],
            "labels": [
                "1-2",
                "3-4",
                "5-6",
                "7-8",
                "9+"
            ],
            "mapping": {
                "1-2": 0,
                "3-4": 1,
                "5-6": 2,
                "7-8": 3,
                "9+": 4
            }
        },
        "income_per_member": {
            "method": "ratio",
            "formula": "monthly_income / household_size",
            "description": "Income per household member (poverty intensity)"
        },
        "education_age_ratio": {
            "method": "ratio",
            "formula": "education_head / (age_head + 1)",
            "description": "Education level relative to age (human capital development)"
        },
        "asset_proxy": {
            "method": "weighted_composite",
            "formula": "(4-house_type)*0.4 + has_electricity*0.3 + (5-water_source)*0.3",
            "description": "Composite asset index proxy (housing + electricity + water)"
        },
        "education_employment_interaction": {
            "method": "multiplicative_interaction",
            "formula": "education_head * employment_head",
            "description": "Interaction between education and employment status"
        },
        "housing_electricity_interaction": {
            "method": "multiplicative_interaction",
            "formula": "(4-house_type) * has_electricity",
            "description": "Better housing with electricity access (infrastructure synergy)"
        }
    },
